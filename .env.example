# ============================================================
# Local Artisan & Repair Service Booking — Environment Config
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ─── Database ───────────────────────────────────────────────
# SQLite (local development)
DATABASE_URL="file:./dev.db"
# PostgreSQL (production)
# DATABASE_URL="postgresql://user:password@localhost:5432/artisan_db?schema=public"

# ─── NextAuth.js ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (SMTP) ──────────────────────────────────────────
# Use Mailtrap for dev, SendGrid/Mailgun for production
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="2525"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@artisan-marketplace.local"

# ─── File Uploads ──────────────────────────────────────────
# Max file size in bytes (5MB default)
MAX_FILE_SIZE="5242880"
# Allowed MIME types (comma-separated)
ALLOWED_MIME_TYPES="image/jpeg,image/png,image/webp,image/avif"
# Upload directory (relative to project root)
UPLOAD_DIR="./public/uploads"

# ─── Rate Limiting ─────────────────────────────────────────
# Max requests per window per IP
RATE_LIMIT_MAX="100"
# Window duration in milliseconds (15 minutes)
RATE_LIMIT_WINDOW_MS="900000"

# ─── Application ───────────────────────────────────────────
APP_NAME="Artisan Marketplace"
APP_URL="http://localhost:3000"
DEFAULT_LOCALE="en"

# ─── Admin Credentials (for seeding) ──────────────────────
ADMIN_EMAIL="admin@artisan-marketplace.local"
ADMIN_PASSWORD="Admin123!@#"

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL="info"
# Options: debug, info, warn, error
